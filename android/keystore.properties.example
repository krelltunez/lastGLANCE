# Android release signing for lastGLANCE.
# Copy to android/keystore.properties (gitignored) and fill in real values.
#
# Generate a keystore once with:
#   keytool -genkey -v -keystore lastglance-release.keystore \
#     -alias lastglance -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to the android/ directory (or use an absolute path).
storeFile=lastglance-release.keystore
storePassword=CHANGEME
keyAlias=lastglance
keyPassword=CHANGEME
